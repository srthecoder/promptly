{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "promptly",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "streamlit", "run", "app/main.py", "--server.headless", "true", "--server.port", "8501"],
      "port": 8501,
      "autoPort": false
    },
    {
      "name": "extension-preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "${PORT}", "--directory", "extension"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
